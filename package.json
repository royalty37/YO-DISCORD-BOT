    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "@swc/core": "^1.3.30",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.11.17",
    "@types/node-schedule": "^2.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.30.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^8.8.0",
