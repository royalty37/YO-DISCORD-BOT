# ===========================
# Discord Bot Configuration
# ===========================

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=

# Discord application/client ID (from Discord Developer Portal)
CLIENT_ID=

# Guild (server) ID the bot operates in
GUILD_ID=

# Text channel ID dedicated to the bot for automated messages
BOT_CHANNEL_ID=

# ===========================
# Role IDs
# ===========================

# "Vice Plus" role ID — the default role for active members
VICE_PLUS_ROLE_ID=

# "Bumboy" role ID — the demotion role used by the bumboy command
BUMBOY_ROLE_ID=

# ===========================
# User IDs
# ===========================

# Admin/president user ID — the only user allowed to force-clear bumboys
ADMIN_USER_ID=

# ===========================
# Database
# ===========================

# MongoDB connection URI
MONGODB_URI=

# ===========================
# Moderation
# ===========================

# Comma-separated list of banned words (optional)
# Example: word1, word2, word3
BANNED_WORDS=

# ===========================
# Development
# ===========================

# Set to any value to enable dev mode (disables scheduled jobs)
# DEV=true
